# Network binding and host ports (host->container)
BIND_ADDRESS=127.0.0.1
RAW_VNC_HOST_PORT=15900
VNC_WS_HOST_PORT=16080
CDP_HOST_PORT=19222
API_HOST_PORT=18080

# Display settings
DISPLAY_NUM=99
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1080
SCREEN_DEPTH=24
SHM_SIZE=2gb

# Browser behavior
BROWSER_START_URL=https://www.google.com
CHROMIUM_NO_SANDBOX=0
CHROMIUM_FLAGS=

# API server (inside container)
API_PORT=8080

# Client SPA server on host
AUTO_START_CLIENT_SERVER=1
AUTO_STOP_CLIENT_SERVER=1
CLIENT_BIND_ADDRESS=127.0.0.1
CLIENT_PORT=3000

# Security credentials (optional)
# Leave empty for no API auth / no VNC password.
VNC_PASSWORD=
API_KEY=

# Runtime
TZ=UTC
